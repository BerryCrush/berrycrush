# Test file for scenario-level parameters feature

parameters:
  shareVariablesAcrossScenarios: true
  timeout: 30

feature: Pet API with parameters
  parameters:
    environment: staging
    timeout: 60

  scenario: Create pet with custom timeout
    parameters:
      timeout: 120
      retries: 3
    when I create a pet
      call ^createPet
        name: "Fluffy"
      assert status 201

  scenario: List pets with default timeout
    when I list all pets
      call ^listPets
      assert status 200

outline: Test multiple pets with parameters
  parameters:
    timeout: 90
  when I get pet by ID
    call ^getPetById
      petId: "<id>"
    assert status 200
  examples:
    | id |
    | 1  |
    | 2  |
    | 3  |
