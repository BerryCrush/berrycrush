# =============================================================================
# Microservices - Inventory Service Scenarios
# =============================================================================
# Demonstrates testing an inventory management microservice

# -----------------------------------------------------------------------------
# List Inventory
# -----------------------------------------------------------------------------

scenario: List all inventory items
  when: I request all inventory items
    call ^listInventory
  then: I receive a list of items
    assert status 200
    assert $.length() >= 1

# -----------------------------------------------------------------------------
# Get Inventory Item by SKU
# -----------------------------------------------------------------------------

scenario: Get inventory item by SKU
  when: I request a specific item
    call ^getInventoryItem
      sku: "SKU-001"
  then: I receive the item details
    assert status 200
    assert $.sku equals "SKU-001"
    assert $.name notEmpty
    assert $.quantity > 0

scenario: Get non-existent item returns 404
  when: I request an item that doesn't exist
    call ^getInventoryItem
      sku: "NON-EXISTENT"
  then: I receive a not found error
    assert status 404

# -----------------------------------------------------------------------------
# Create Inventory Item
# -----------------------------------------------------------------------------

scenario: Create a new inventory item
  when: I create an inventory item
    call ^createInventoryItem
      body:
        sku: "NEW-SKU-001"
        name: "New Product"
        quantity: 50
        unitPrice: 29.99
  then: the item is created
    assert status 201
    assert $.sku equals "NEW-SKU-001"
    assert $.quantity equals 50

# -----------------------------------------------------------------------------
# Check Availability
# -----------------------------------------------------------------------------

scenario: Check item availability - sufficient stock
  when: I check availability
    call ^checkAvailability
      sku: "SKU-001"
      quantity: 5
  then: item is available
    assert status 200
    assert $.available equals true
    assert $.availableQuantity >= 5

scenario: Check item availability - insufficient stock
  when: I check availability for large quantity
    call ^checkAvailability
      sku: "SKU-001"
      quantity: 10000
  then: item is not available
    assert status 200
    assert $.available equals false

# -----------------------------------------------------------------------------
# Reserve Inventory
# -----------------------------------------------------------------------------

scenario: Reserve inventory for an order
  given: the item is available
    call ^checkAvailability
      sku: "SKU-002"
      quantity: 2
    assert status 200
    assert $.available equals true
  when: I reserve inventory
    call ^reserveInventory
      sku: "SKU-002"
      quantity: 2
  then: inventory is reserved
    assert status 200
    assert $.reservedQuantity equals 2
