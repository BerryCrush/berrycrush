# Scenarios for testing initial game state

scenario: Initial board is empty
  when: I request the board
    call ^getBoard
  then: The board is empty with no winner
    assert status 200
    assert $.winner equals "."
    assert $.board[0][0] equals "."
    assert $.board[1][1] equals "."
    assert $.board[2][2] equals "."

scenario: Get empty square returns dot
  when: I request square (2,2)
    call ^getSquare
      row: 2
      column: 2
  then: The square is empty
    assert status 200
    assert $ equals "."

scenario: Reset clears the board
  given: A mark exists on the board
    call ^putSquare
      row: 1
      column: 1
      body: {"mark": "X"}
    assert status 200
  when: I reset the board
    call ^resetBoard
  then: The board is empty again
    assert status 200
    assert $.winner equals "."
    assert $.board[0][0] equals "."
