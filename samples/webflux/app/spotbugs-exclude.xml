<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude ENTITY_LEAK warnings - this is a sample project demonstrating
         API patterns, not production code. In real applications, use DTOs. -->
    <Match>
        <Bug pattern="ENTITY_LEAK"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Exclude entity exposure warnings for sample controllers -->
    <Match>
        <Class name="~org\.berrycrush\..*Controller"/>
        <Bug category="SECURITY"/>
    </Match>
</FindBugsFilter>
