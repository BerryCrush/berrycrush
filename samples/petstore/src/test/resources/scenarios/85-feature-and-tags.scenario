# Demonstrates feature blocks, background steps, and tags
# Tags are used to categorize and filter scenarios
# Features provide logical grouping with shared background steps

@feature @api
feature: Pet Store Tag and Feature Demo
  background:
    given: create a test pet for demo
      call ^createPet
        body: {"name": "FeatureDemoPet", "status": "available"}
      assert status 201

  scenario: list all pets in feature
    when: list pets
      call ^listPets
      assert status 200

  @slow
  scenario: slow operation with pagination
    when: list multiple times
      call ^listPets
      assert status 200
      call ^listPets
      assert status 200
      call ^listPets
      assert status 200

  @ignore
  scenario: ignored scenario should be skipped
    when: this should not run
      call ^listPets
      assert status 500  # would fail if it ran

  @wip
  scenario: work in progress feature
    when: list all pets
      call ^listPets
      assert status 200

  # This scenario has both @api (from feature) and @ignore - should be excluded
  # when testing with include=api + exclude=ignore
  @api @ignore
  scenario: api tagged but also ignored
    when: this should also not run
      call ^listPets
      assert status 500  # would fail if it ran

# Standalone scenario with tags (not in a feature)
@standalone
scenario: standalone tagged scenario
  given: check auth endpoint
    call ^listPets
    assert status 200

# Standalone API-only scenario (no @ignore) for testing include filter
@api
scenario: standalone api scenario
  given: list pets via api
    call ^listPets
    assert status 200
