# Comprehensive Assertion Test Scenario
# Tests all supported assertion types in the BerryCrush library

# Test status code assertions
scenario: Status code assertions
  when: list pets
    call ^listPets
  then: verify status code variants
    assert status 200
    assert statusCode 200

# Test body contains assertions
scenario: Body contains assertions
  given: create a pet for testing
    call ^createPet
      body: {"name": "AssertionTestPet", "status": "available", "category": "test"}
    assert status 201
  when: get the pet list
    call ^listPets
  then: body should contain pet data
    assert contains "AssertionTestPet"

# Test JSONPath equals assertions
scenario: JSONPath equals assertions
  when: get pet by ID
    call ^getPetById
      petId: 1
  then: verify exact values
    assert $.id equals 1
    assert $.name = "Max"
    assert $.status equals "available"

# Test JSONPath matches (regex) assertions
scenario: JSONPath regex matching
  when: get pet list
    call ^listPets
  then: verify patterns match
    # Total should be a number
    assert $.total matches "\\d+"

# Test array assertions
scenario: Array assertions
  when: get all pets
    call ^listPets
  then: verify array properties
    # Array should not be empty
    assert $.pets notEmpty
    # Total count should match pets array size
    assert $.total matches "\\d+"

# Test header exists assertion
scenario: Header exists assertion
  when: make any request
    call ^listPets
  then: verify response headers
    assert header Content-Type

# Test header equals assertion
scenario: Header equals assertions
  when: make request
    call ^listPets
  then: verify exact header values
    assert header Content-Type = "application/json"
    assert header Content-Type: "application/json"

# Test response time assertion
scenario: Response time assertion
  when: make fast request
    call ^listPets
  then: response should be quick
    # Response should complete within 5 seconds (generous limit for CI)
    assert responseTime 5000

# Test schema validation assertion
scenario: Schema validation assertion
  when: get pet by ID
    call ^getPetById
      petId: 1
  then: response should match schema
    assert status 200
    # Schema validation against the OpenAPI spec
    assert schema

# Test multiple assertions in a single step
scenario: Multiple assertions combined
  when: create and verify pet
    call ^createPet
      body: {"name": "MultiAssertPet", "status": "pending", "category": "dogs", "price": 199.99}
  then: verify all response aspects
    assert status 201
    assert $.name equals "MultiAssertPet"
    assert $.status = "pending"
    assert header Content-Type = "application/json"
