# Authentication Scenario
# Tests the authentication endpoints: login and logout
# Uses the 'auth' spec registered via PetstoreBindings.getAdditionalSpecs()

scenario: Authentication - Successful Login
  given I have valid credentials
    call using auth ^login
      body: {"username": "test", "password": "test"}
  then authentication returns a token
    assert status 200
    extract $.token => authToken

scenario: Authentication - Invalid Credentials
  given I have invalid credentials
    call using auth ^login
      body: {"username": "test", "password": "wrongpassword"}
  then authentication fails
    assert status 401

scenario: Authentication - Missing Credentials
  given I have missing password
    call using auth ^login
      body: {"username": "test"}
  then request is rejected
    assert status 400

scenario: Authentication - Logout
  when I log out
    call using auth ^logout
  then logout is successful
    assert status 200
