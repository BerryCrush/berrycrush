@conditional @smoke
scenario: Conditional Assertion Demo - Upsert Pet
  given the API is available
    call ^listPets
    assert status 200

  when I upsert a pet that doesn't exist (should create)
    call ^updatePet
      petId: 9001
      body:
        name: "UpsertedPet"
        status: "available"

  then I verify creation via conditional
    if status 201
      # Pet was created (ID 9001 didn't exist)
      assert $.id equals 9001
      assert $.name equals "UpsertedPet"
      assert $.status equals "available"
    else if status 200
      # Pet already existed and was updated
      assert $.id equals 9001
      assert $.name equals "UpsertedPet"
    else
      fail "Expected status 200 or 201 for upsert operation"

@conditional
scenario: Conditional Assertion Demo - Update Existing Pet
  given I create a pet first
    call ^createPet
      body:
        name: "ExistingPet"
        status: "pending"
    assert status 201
    extract $.id => petId

  when I upsert the same pet (should update)
    call ^updatePet
      petId: {{petId}}
      body:
        name: "UpdatedPet"
        status: "available"

  then I verify update via conditional
    if status 200
      # Existing pet was updated
      assert $.id equals {{petId}}
      assert $.name equals "UpdatedPet"
      assert $.status equals "available"
    else if status 201
      # Should not happen since pet exists
      fail "Expected 200 for existing pet update, got 201"
    else
      fail "Expected status 200 for update operation"

@conditional @jsonpath
scenario: Conditional Based on JSON Path
  given I get pets list
    call ^listPets
    assert status 200
    extract $.total => totalPets

  then I check the result conditionally
    if $.total greaterThan 0
      assert $.pets[0].id notEmpty
    else
      # Empty list is acceptable
      assert $.pets size 0

@conditional @header
scenario: Conditional Based on Header
  when I call the API
    call ^listPets

  then I check content type
    if header Content-Type equals "application/json"
      assert status 200
      assert $.pets notEmpty
    else
      fail "Expected JSON response"

@conditional @nested
scenario: Nested Conditionals with Upsert
  when I upsert a pet with nested conditional check
    call ^updatePet
      petId: 9002
      body:
        name: "NestedTestPet"
        status: "available"

    if status 201
      # Pet was created
      assert $.id equals 9002
      if $.status equals "available"
        assert $.name equals "NestedTestPet"
      else
        fail "Created pet should be available"
    else if status 200
      # Pet was updated - also valid
      assert $.id notEmpty
      if $.name equals "NestedTestPet"
        assert $.status equals "available"
      else
        # Name was different - that's okay for update
        assert $.id equals 9002
    else
      fail "Expected status 200 or 201"

@conditional
scenario: Fail Action Demo
  when I request a non-existent pet
    call ^getPetById
      petId: 999999

  then I expect not found
    if status 404
      assert $.message notEmpty
    else if status 200
      # Somehow the pet exists - that's okay
      assert $.id notEmpty
    else
      fail "Expected 404 for non-existent pet"

@conditional
outline: Conditional with Parameterized Upsert
  when I upsert pet with ID {{id}} and name {{name}}
    call ^updatePet
      petId: {{id}}
      body:
        name: "{{name}}"
        status: "available"

    if status 201
      # Created new pet
      assert $.id equals {{id}}
      assert $.name equals "{{name}}"
    else if status 200
      # Updated existing pet
      assert $.name equals "{{name}}"
    else if status 400
      # Invalid input - check error message
      assert $.message notEmpty
    else
      fail "Unexpected status code for upsert"

  examples:
    | id   | name       |
    | 9003 | UpsertPet1 |
    | 9004 | UpsertPet2 |
