# =============================================================================
# Auto Testing
# =============================================================================
# This scenario file demonstrates:
# - auto: [invalid security] directive for auto-generated tests
# - excludes: to filter test types
# - Context variables: test.type, test.field, test.description, test.value
# - Custom test providers (InvalidTestProvider, SecurityTestProvider)
# - Multi-test parameters at different levels

# -----------------------------------------------------------------------------
# File-level parameters
# -----------------------------------------------------------------------------
# These parameters apply to ALL scenarios in this file as defaults.
# Feature-level and step-level parameters override these.
parameters:
  # Default counts for multi-tests (same as built-in defaults for clarity)
  multiTestSequentialCount: 3
  multiTestConcurrentCount: 5
  # You can add other file-level settings here, like:
  # timeout: 30
  # shareVariablesAcrossScenarios: false

# -----------------------------------------------------------------------------
# Auto-generated invalid tests
# -----------------------------------------------------------------------------

scenario: Auto-generated invalid tests - basic
  when: I create a pet with invalid input
    call ^createPet
      # Generate tests that violate OpenAPI schema constraints
      auto: [invalid]
      # Base request - valid values that will be mutated
      body:
        name: TestPet
        status: available
    
    # Invalid requests should be rejected with 4xx
    if status 4xx
      # Test passed - invalid request was properly rejected
    else
      # Log why the test failed using context variables
      fail "Expected 4xx for {{test.type}}: {{test.field}} - {{test.description}}"

# -----------------------------------------------------------------------------
# Auto-generated security tests
# -----------------------------------------------------------------------------

scenario: Auto-generated security tests - basic
  when: I create a pet with security payloads
    call ^createPet
      # Generate tests with common attack payloads
      auto: [security]
      body:
        name: SecurePet
        status: available
    
    if status 4xx
      # Security payload was rejected - good
    else if status 5xx
      # Server error from security payload - might indicate vulnerability
      fail "Server error from security test: {{test.description}}"
    else
      # Success might mean payload was accepted - investigate
      fail "Security test did not trigger error: {{test.type}} on {{test.field}}"

# -----------------------------------------------------------------------------
# Combined invalid and security tests
# -----------------------------------------------------------------------------

scenario: Auto-generated tests - both invalid and security
  when: I test the createPet endpoint
    call ^createPet
      # Generate both invalid and security tests
      auto: [invalid security]
      body:
        name: CombinedTestPet
        status: available
    
    if status 4xx
      # Either invalid constraint violation or security payload rejection
    else
      fail "Test failed for {{test.type}}: {{test.description}}"

# -----------------------------------------------------------------------------
# Exclude specific test types
# -----------------------------------------------------------------------------

scenario: Auto-generated tests - with excludes
  when: I test with some types excluded
    call ^createPet
      auto: [invalid]
      # Exclude specific types of invalid tests
      excludes: [overflow string_length]
      body:
        name: ExcludeTestPet
        status: available
    
    if status 4xx
      # Test passed
    else
      fail "Test failed: {{test.description}}"

# -----------------------------------------------------------------------------
# Using test context variables
# -----------------------------------------------------------------------------

scenario: Test context variables - detailed verification
  when: I create pet with auto tests
    call ^createPet
      auto: [invalid security]
      body:
        name: ContextVarPet
        status: available
    
    # Use context variables to provide detailed failure messages
    if status 4xx
      # Expected rejection
    else if status 5xx
      fail "Server error for {{test.type}} test on {{test.field}}: {{test.description}} with value: {{test.value}}"
    else
      fail "Test passed unexpectedly: Type={{test.type}}, Field={{test.field}}, Location={{test.location}}"

# -----------------------------------------------------------------------------
# Auto tests for different endpoints
# -----------------------------------------------------------------------------

scenario: Auto tests for update endpoint
  # First create a pet to update
  given: I have a pet to test
    call ^createPet
      body: {"name": "UpdateAutoTestPet", "status": "available"}
    extract $.id => autoTestPetId
  when: I test update with invalid input
    call ^updatePet
      auto: [invalid]
      petId: {{autoTestPetId}}
      body:
        id: {{autoTestPetId}}
        name: UpdateAutoTestPet
        status: available
    
    if status 4xx
      # Invalid update rejected
    else
      fail "Update test failed: {{test.description}}"

# -----------------------------------------------------------------------------
# Custom test providers (via ServiceLoader)
# -----------------------------------------------------------------------------

# Custom test providers are Java classes that implement:
# - InvalidTestProvider: generates custom invalid test cases
# - SecurityTestProvider: generates custom security test cases
#
# They are discovered via ServiceLoader and registered in:
# META-INF/services/org.berrycrush.autotest.provider.InvalidTestProvider
# META-INF/services/org.berrycrush.autotest.provider.SecurityTestProvider
#
# Example custom provider implementation:
#
# public class PetNameInvalidTestProvider implements InvalidTestProvider {
#     @Override
#     public List<InvalidTestCase> generateCases(OpenApiSpec spec, Operation op) {
#         // Return list of custom invalid test cases
#     }
# }

scenario: Custom test providers - using custom invalid tests
  when: I create pet with custom invalid tests
    call ^createPet
      # Custom providers add their test cases to [invalid]
      auto: [invalid]
      body:
        name: CustomProviderPet
        status: available
    
    # Handle both built-in and custom provider test cases
    if status 4xx
      # Custom or built-in invalid test passed
    else
      fail "Custom invalid test failed: {{test.type}} - {{test.field}}"

scenario: Custom test providers - using custom security tests
  when: I create pet with custom security tests
    call ^createPet
      # Custom providers add their test cases to [security]
      auto: [security]
      body:
        name: SecurityProviderPet
        status: available
    
    if status 4xx
      # Security payload rejected
    else
      fail "Custom security test failed: {{test.description}}"

# -----------------------------------------------------------------------------
# Multi/Idempotency tests
# -----------------------------------------------------------------------------

# Multi tests verify API idempotency by executing the same request multiple times.
# They run in two modes:
# - SEQUENTIAL: requests one after another (default: 3)
# - CONCURRENT: requests simultaneously (default: 5)

scenario: Multi test - idempotency for GET endpoint
  # First create a pet to test idempotency on
  given: I have a pet to test idempotency
    call ^createPet
      body: {"name": "IdempotencyTestPet", "status": "available"}
    extract $.id => idempotentPetId
  when: I get the pet multiple times
    call ^getPetById
      # Generate idempotency tests - sequential and concurrent
      auto: [multi]
      petId: {{idempotentPetId}}
    
    # All multi-test requests should succeed consistently
    if status 2xx
      # Idempotency test passed - all requests returned consistent results
    else
      fail "Multi test failed: expected 2xx for idempotent GET operation"

scenario: Multi test - with custom counts
  # Step-level parameters: multiTestSequentialCount and multiTestConcurrentCount
  # can be specified directly in the call directive
  given: I have a pet for heavy testing
    call ^createPet
      body: {"name": "HeavyTestPet", "status": "available"}
    extract $.id => heavyPetId
  when: I stress test the GET endpoint
    call ^getPetById
      auto: [multi]
      petId: {{heavyPetId}}
      # Override default counts at step level
      multiTestSequentialCount: 5
      multiTestConcurrentCount: 10
    
    if status 2xx
      # All requests passed
    else
      fail "Heavy multi test failed"

scenario: Multi test - combined with other auto tests
  given: I have a pet for comprehensive testing
    call ^createPet
      body: {"name": "ComprehensiveMultiPet", "status": "available"}
    extract $.id => comprehensivePetId
  when: I run all auto tests including multi
    call ^getPetById
      # Combine multi with invalid and security tests
      auto: [invalid security multi]
      petId: {{comprehensivePetId}}
    
    if test.type equals invalid and status 4xx
      # Invalid request correctly rejected
    else if test.type equals security and status 4xx
      # Security attack blocked
    else if test.type equals multi and status 2xx
      # Multi/idempotency test passed
    else if status 2xx
      # Some edge case passed - review
    else
      fail "Test failed: {{test.type}} - {{test.description}}"

scenario: Multi test - with excludes
  # You can exclude specific multi test modes
  # Available modes: SEQUENTIAL, CONCURRENT
  given: I have a pet for sequential-only testing
    call ^createPet
      body: {"name": "SequentialOnlyPet", "status": "available"}
    extract $.id => sequentialPetId
  when: I run only sequential multi tests
    call ^getPetById
      auto: [multi]
      # Exclude concurrent tests - only run sequential
      excludes: [CONCURRENT]
      petId: {{sequentialPetId}}
    
    if status 2xx
      # Sequential multi test passed
    else
      fail "Sequential multi test failed"

# -----------------------------------------------------------------------------
# Feature-level parameters for multi-tests
# -----------------------------------------------------------------------------

feature: Multi Tests with Feature Parameters
  # Feature-level parameters apply to all scenarios in this feature
  parameters:
    multiTestSequentialCount: 4
    multiTestConcurrentCount: 8
  
  scenario: Feature parameter multi test
    given: I have a pet for feature-level testing
      call ^createPet
        body: {"name": "FeatureParamPet", "status": "available"}
      extract $.id => featureParamPetId
    when: I run multi tests with feature-level counts
      call ^getPetById
        auto: [multi]
        petId: {{featureParamPetId}}
      
      if status 2xx
        # Uses 4 sequential and 8 concurrent from feature parameters
      else
        fail "Feature parameter multi test failed"

# -----------------------------------------------------------------------------
# Comprehensive auto test scenario
# -----------------------------------------------------------------------------

scenario: Comprehensive auto testing
  when: I thoroughly test the createPet endpoint
    call ^createPet
      auto: [invalid security]
      body:
        name: ComprehensivePet
        status: available
        category: cat
        tags: ["test", "comprehensive"]
    
    if status 4xx
      # Test generated expected rejection
    else if status 2xx
      # Some test cases might legitimately pass (edge cases)
      # Log it for review
    else
      # 5xx or other unexpected status
      fail "Unexpected response for {{test.type}} test: {{test.description}}"
