# Tests for the BUT keyword - exception/negative case steps

scenario: Test BUT keyword with negative assertion
  when: get non-existent pet
    call ^getPetById
      petId: 99999
  then: response indicates not found
    assert status 404
  but: response still has headers
    assert header Content-Type

scenario: BUT keyword in verification flow
  given: verify API is available
    call ^listPets
    assert status 200
  when: get a pet by ID
    call ^getPetById
      petId: 1
  then: pet is returned
    assert status 200
    assert $.name equals "Max"
  but: pet is not in sold status
    assert $.status equals "available"
