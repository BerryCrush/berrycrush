# Parallel Execution Demo - Isolated Variables
#
# These scenarios demonstrate isolated ExecutionContext.
# Each scenario has its own variable scope, ensuring no interference.
#
# Thread Safety Note:
# - Each scenario gets an isolated copy of ExecutionContext
# - Variables set in one scenario don't affect others
# - This allows safe parallel execution

scenario: Create and Verify Pet 1 (Isolated Context)
  tags: parallel, isolation
  when I create pet one
    call ^createPet
      body:
        name: "Pet-One"
        status: "available"
    extract $.id => petId
  then verify my pet id is stored
    assert $.id equals {{petId}}
  and I can retrieve my pet
    call ^getPetById
      petId: {{petId}}
    assert $.name equals "Pet-One"

