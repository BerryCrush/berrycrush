# Parallel Execution Demo - Create Pets
#
# This scenario file demonstrates parallel execution capabilities.
# Each scenario is independent and can run concurrently with others.

scenario: Create Cat (Parallel)
  tags: parallel, create
  when I create a cat
    call ^createPet
      body:
        name: "Whiskers"
        status: "available"
  then the cat is created
    assert status 201
    assert $.name equals "Whiskers"

