# Scenario: List all pets from the store
scenario: List all pets
  when I request the list of pets
    call ^listPets
  then I get a successful response
    assert status 200
    assert $.pets notEmpty

# Scenario: Authenticated access to pet list
# Demonstrates fragment inclusion for reusable authentication
scenario: Authenticated list pets
  given I authenticate first
    include authenticate
  when I request the list of pets with auth
    call ^listPets
  then I get a successful response
    assert status 200
