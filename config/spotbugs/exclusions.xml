<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Exclusion Filter for BerryCrush
  https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter>
    <!-- Exclude test classes from certain checks -->
    <Match>
        <Class name="~.*Test.*"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    
    <!-- Exclude Kotlin-generated code patterns -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
        <Class name="~.*\$.*"/>
    </Match>
    
    <!-- Exclude data classes auto-generated equals/hashCode -->
    <Match>
        <Bug pattern="EQ_UNUSUAL"/>
        <Method name="equals"/>
    </Match>
    
    <!-- Allow serialVersionUID in serializable classes -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
        <Field name="serialVersionUID"/>
    </Match>
    
    <!-- Exclude Spring configuration classes from unread field checks -->
    <Match>
        <Class name="~.*Config.*"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    
    <!-- Exclude DSL builders from naming conventions -->
    <Match>
        <Class name="~.*Scope.*"/>
        <Bug pattern="NM_METHOD_NAMING_CONVENTION"/>
    </Match>
    
    <!-- Exclude generated code -->
    <Match>
        <Package name="~.*\.generated\..*"/>
    </Match>

    <!-- Exclude sample project-->
    <Match>
        <Package name="~.*\.samples\..*"/>
    </Match>
    
    <!-- ========================================== -->
    <!-- Kotlin-specific patterns                   -->
    <!-- ========================================== -->
    
    <!-- Data classes expose internal representation via getters - this is by design in Kotlin -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    
    <!-- Java keyword conflicts - 'assert' and 'enum' are intentional API names -->
    <Match>
        <Bug pattern="NM_FUTURE_KEYWORD_USED_AS_IDENTIFIER"/>
    </Match>
    <Match>
        <Bug pattern="NM_FUTURE_KEYWORD_USED_AS_MEMBER_IDENTIFIER"/>
    </Match>
    
    <!-- AssertionFailureException is named for clarity, not inheritance -->
    <Match>
        <Bug pattern="NM_CLASS_NOT_EXCEPTION"/>
        <Class name="org.berrycrush.exception.AssertionFailureException"/>
    </Match>
    
    <!-- Singleton objects in Kotlin have public constructors by design -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_REFACTORED_TO_BE_FINAL"/>
    </Match>
    <Match>
        <Bug pattern="SING_SINGLETON_HAS_NONPRIVATE_CONSTRUCTOR"/>
    </Match>
    
    <!-- Repeated conditionals are sometimes clearer than complex boolean expressions -->
    <Match>
        <Bug pattern="RpC_REPEATED_CONDITIONAL_TEST"/>
    </Match>
    
    <!-- Dead store in Kotlin - often from destructuring or when expressions -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>
    
    <!-- Redundant null checks - Kotlin's null safety handles this -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE"/>
    </Match>
    
    <!-- Boxing/unboxing - Kotlin handles this automatically -->
    <Match>
        <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED"/>
    </Match>
    
    <!-- Unused private methods - may be used via reflection or planned for future use -->
    <Match>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
    </Match>
    
    <!-- Collection casts - Kotlin collections are often cast between interfaces -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>
    
    <!-- ========================================== -->
    <!-- Security patterns (Find Security Bugs)     -->
    <!-- These are acceptable in a test framework   -->
    <!-- ========================================== -->
    
    <!-- SSRF - BerryCrush is a test framework that intentionally makes HTTP requests -->
    <Match>
        <Bug pattern="URLCONNECTION_SSRF_FD"/>
    </Match>
    <Match>
        <Bug pattern="SSRF"/>
    </Match>
    
    <!-- Path traversal - Test framework reads scenario/spec files by design -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>
    <Match>
        <Bug pattern="PT_ABSOLUTE_PATH_TRAVERSAL"/>
    </Match>
    
    <!-- XML injection - Report generation builds XML from test data -->
    <Match>
        <Bug pattern="XSS_SERVLET"/>
    </Match>
    <Match>
        <Bug pattern="XML_INJECTION"/>
    </Match>
    <Match>
        <Bug pattern="POTENTIAL_XML_INJECTION"/>
    </Match>
    
    <!-- CRLF injection - Logging test data is intentional -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>
    
    <!-- Unicode handling - Test framework processes various input formats -->
    <Match>
        <Bug pattern="IMPROPER_UNICODE"/>
    </Match>
    
    <!-- ========================================== -->
    <!-- Code style patterns (Kotlin idioms)        -->
    <!-- ========================================== -->
    
    <!-- Null path checks - Kotlin null safety and Elvis operators -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>
    
    <!-- Cast patterns - Kotlin's smart casts and type system -->
    <Match>
        <Bug pattern="BC_UNCONFIRMED_CAST_OF_RETURN_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="BC_IMPOSSIBLE_INSTANCEOF"/>
    </Match>
    
    <!-- Duplicate branches - Kotlin when expressions often have similar branches -->
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES"/>
    </Match>
    <Match>
        <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES"/>
    </Match>
    
    <!-- Self-assignment - Kotlin property initialization patterns -->
    <Match>
        <Bug pattern="SA_LOCAL_SELF_ASSIGNMENT"/>
    </Match>
    
    <!-- Static field writes - Kotlin companion object initialization -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>
    
    <!-- Void methods - May have side effects or be used for DSL fluency -->
    <Match>
        <Bug pattern="UC_USELESS_VOID_METHOD"/>
    </Match>
    
    <!-- ========================================== -->
    <!-- Test code patterns                         -->
    <!-- ========================================== -->
    
    <!-- Naming conventions - Test methods use descriptive names -->
    <Match>
        <Bug pattern="NM_CONFUSING"/>
    </Match>
    <Match>
        <Bug pattern="NM_METHOD_NAMING_CONVENTION"/>
    </Match>
    
    <!-- Public attributes - Test fixtures expose data intentionally -->
    <Match>
        <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
    </Match>
    
    <!-- Runtime exceptions - Tests may throw for validation -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
    </Match>
    
    <!-- Default encoding - Acceptable in test context -->
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
    </Match>
    
    <!-- Blocking URL methods - Test framework uses URL operations -->
    <Match>
        <Bug pattern="DMI_BLOCKING_METHODS_ON_URL"/>
    </Match>
    
    <!-- Unread fields - Kotlin properties may be used via reflection -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    
    <!-- Unwritten fields - Kotlin data classes and late initialization -->
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    
    <!-- Null safety - Kotlin handles nullability at compile time -->
    <Match>
        <Bug pattern="NP_NONNULL_RETURN_VIOLATION"/>
    </Match>
    <Match>
        <Bug pattern="NP_NULL_PARAM_DEREF"/>
    </Match>
    
    <!-- Anonymous class methods - Kotlin lambdas compiled to anonymous classes -->
    <Match>
        <Bug pattern="UMAC_UNCALLABLE_METHOD_OF_ANONYMOUS_CLASS"/>
    </Match>
</FindBugsFilter>
